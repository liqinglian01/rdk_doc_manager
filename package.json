{
  "name": "rdk-doc",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "generate-sidebar-config": "node scripts/generate-sidebar-config.js",
    "watch-sidebar-config": "node scripts/watch-sidebar-config.js",
    "start": "npm run generate-sidebar-config && concurrently --kill-others --raw \"npm run watch-sidebar-config\" \"docusaurus start --locale zh-Hans\"",
    "start:en": "npm run generate-sidebar-config && concurrently --kill-others --raw \"npm run watch-sidebar-config\" \"docusaurus start --locale en\"",
    "start:port": "npm run generate-sidebar-config && concurrently --kill-others --raw \"npm run watch-sidebar-config\" \"docusaurus start --port 3001 --locale zh-Hans\"",
    "start:no-watch": "npm run generate-sidebar-config && docusaurus start --locale zh-Hans",
    "start:no-watch:en": "npm run generate-sidebar-config && docusaurus start --locale en",
    "build": "npm run generate-sidebar-config && docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "npm run generate-sidebar-config && docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids"
  },
  "dependencies": {
    "@docusaurus/core": "^3.7.0",
    "@docusaurus/plugin-sitemap": "^3.8.1",
    "@docusaurus/preset-classic": "^3.7.0",
    "@docusaurus/theme-mermaid": "3.8.1",
    "@easyops-cn/docusaurus-search-local": "^0.52.2",
    "@giscus/react": "^3.0.0",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.0.0",
    "medium-zoom": "^1.1.0",
    "prism-react-renderer": "^2.3.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "remark-directive": "^4.0.0",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.7.0",
    "@docusaurus/types": "^3.7.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0"
  }
}
